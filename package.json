{
  "name": "@livelayer/react",
  "version": "0.21.2",
  "description": "LiveLayer agent widget for React — avatar video, team switching, responsive layouts, full-fidelity embed",
  "keywords": [
    "livelayer",
    "ai-agent",
    "voice-agent",
    "avatar",
    "livekit",
    "react",
    "widget"
  ],
  "homepage": "https://livelayer.studio",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@livelayer/sdk": "^0.8.1",
    "livekit-client": "^2.17.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^29.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.0.0",
    "vite": "^6.3.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.1.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Fusion-Studios-Code/live-layer-react.git"
  },
  "bugs": {
    "url": "https://github.com/Fusion-Studios-Code/live-layer-react/issues"
  }
}
